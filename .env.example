# ============================================
# SUPABASE CONFIGURATION
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Custom project keys (optional)
SUPABASE_SECRET_KEY=your-secret-key-here
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# ============================================
# LINE PLATFORM CONFIGURATION
# ============================================
# LINE LIFF Configuration
VITE_LIFF_ID=your-liff-id-here

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token-here
LINE_CHANNEL_SECRET=your-channel-secret-here

# LINE Login (if using)
VITE_LINE_LOGIN_CHANNEL_ID=your-line-login-channel-id-here

# ============================================
# MAPS API
# ============================================
# Using Nominatim OpenStreetMap (free, no API key required)
NOMINATIM_API_URL=https://nominatim.openstreetmap.org

# If you want to use Google Maps instead (optional):
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ============================================
# OTHER SERVICES
# ============================================
# Additional services (if needed)

# ============================================
# APPLICATION CONFIG
# ============================================
# Development mode
VITE_DEV_MODE=false

# API endpoints
VITE_API_BASE_URL=http://localhost:3000
