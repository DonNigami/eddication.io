# PTG eZView API Integration - Environment Configuration

# ============================================
# API CREDENTIALS
# ============================================
PTG_BASE_URL=http://203.151.215.230:9000/eZViewIntegrationService/web-service/api
PTG_USERNAME=LPG_Bulk
PTG_PASSWORD=your_password_here

# ============================================
# DEVICE INFO
# ============================================
PTG_DEVICE_ID=python-integration
PTG_DEVICE_NAME=Python Integration Client
PTG_DEVICE_TYPE=server
PTG_OS=Python

# ============================================
# QUERY PARAMETERS
# ============================================
# Leave empty to fetch all
PTG_STATUS_ID=
PTG_START_DATE=
PTG_END_DATE=
PTG_LIMIT=50

# ============================================
# RATE LIMITING
# ============================================
PTG_RATE_LIMIT_MS=1000
PTG_FAST_MODE=false

# ============================================
# PERFORMANCE
# ============================================
PTG_ADAPTIVE_RATE_LIMIT=true
PTG_MIN_RATE_LIMIT_MS=100
PTG_MAX_RATE_LIMIT_MS=1000
PTG_TARGET_RESPONSE_TIME_MS=500
PTG_LOG_LEVEL=INFO

# ============================================
# STORAGE
# ============================================
# Options: sqlite, csv
PTG_STORAGE_TYPE=sqlite
PTG_SQLITE_PATH=ptg_data.db
PTG_CSV_PATH=csv_output

# ============================================
# SCHEDULE
# ============================================
# Interval in minutes (default: 60)
PTG_SCHEDULE_MINUTES=60
