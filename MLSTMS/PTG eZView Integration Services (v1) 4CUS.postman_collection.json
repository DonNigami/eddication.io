  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (POST /v1/login) - save tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "let r = {};",
                  "try { r = pm.response.json(); } catch(e) { pm.environment.set('lastError', String(e)); }",
                  "if (r && r.data) {",
                  "  const accessToken = r.data.accessToken || '';",
                  "  const refreshToken = r.data.refreshToken || '';",
                  "  pm.collectionVariables.set('accessToken', accessToken);",
                  "  pm.collectionVariables.set('refreshToken', refreshToken);",
                  "  pm.environment.set('accessToken', accessToken);",
                  "  pm.environment.set('refreshToken', refreshToken);",
                  "}",
                  "pm.environment.set('lastLoginAt', new Date().toISOString());"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"deviceInfo\": {\n    \"deviceId\": \"{{deviceId}}\",\n    \"deviceName\": \"{{deviceName}}\",\n    \"deviceType\": \"{{deviceType}}\",\n    \"os\": \"{{os}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token (POST /v1/refresh-token) - rotate tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "let r = {};",
                  "try { r = pm.response.json(); } catch(e) { pm.environment.set('lastError', String(e)); }",
                  "if (r && r.data) {",
                  "  const accessToken = r.data.accessToken || '';",
                  "  const refreshToken = r.data.refreshToken || '';",
                  "  pm.collectionVariables.set('accessToken', accessToken);",
                  "  pm.collectionVariables.set('refreshToken', refreshToken);",
                  "  pm.environment.set('accessToken', accessToken);",
                  "  pm.environment.set('refreshToken', refreshToken);",
                  "}",
                  "pm.environment.set('lastRefreshAt', new Date().toISOString());"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/refresh-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "refresh-token"
              ]
            }
          },
          "response": []
        },
