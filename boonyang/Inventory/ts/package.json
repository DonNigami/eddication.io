/**
 * Package.json
 * Dependencies for Boonyang Inventory TypeScript project
 */

{
  "name": "boonyang-inventory",
  "version": "1.0.0",
  "description": "Boonyang Inventory Management System - TypeScript + Supabase",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "inventory",
    "line-bot",
    "supabase",
    "typescript"
  ],
  "author": "Boonyang Corp",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "express": "^4.18.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "tsx": "^3.14.0",
    "typescript": "^5.1.6",
    "eslint": "^8.45.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
